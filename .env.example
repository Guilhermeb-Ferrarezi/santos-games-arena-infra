# Root env loaded by apps/* and docker-compose.yml.
# Do not put secrets in git. Copy this file to .env locally.

NODE_ENV=development
PORT=3001

DATABASE_URL=postgres://postgres:postgres@localhost:5432/sga_db
REDIS_URL=redis://localhost:6379

AUTH_PUBLIC_URL=https://auth.santos-games.com
AUTH_WEB_PUBLIC_URL=https://auth.santos-games.com
AUTH_COOKIE_NAME=sg_auth
AUTH_COOKIE_DOMAIN=
CORS_ORIGINS=https://auth.santos-games.com
VITE_AUTH_API_URL=https://auth.santos-games.com

CLOUDFLARE_TUNNEL_TOKEN=
AUTH_API_HOSTNAME=auth.santos-games.com
AUTH_WEB_HOSTNAME=auth.santos-games.com

JWT_SECRET=change-this-secret-with-at-least-32-chars

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
STEAM_API_KEY=
